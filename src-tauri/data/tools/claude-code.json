{
  "id": "claudeCode",
  "label": "Claude Code",
  "short": "Claude",
  "kebab": "claude-code",
  "accent": "#D97757",
  "icon": "claudecode",
  "wired": true,
  "order": 1,
  "scope": {
    "user": true,
    "project": true
  },
  "detect": {
    "dirs": [
      ".claude"
    ],
    "agentsDir": ".claude/agents"
  },
  "version": {
    "bin": "claude",
    "args": [
      "--version"
    ]
  },
  "format": "identity",
  "slugFrom": "source",
  "dest": {
    "user": [
      ".claude/agents/{slug}.md"
    ],
    "project": [
      ".claude/agents/{slug}.md"
    ]
  }
}
