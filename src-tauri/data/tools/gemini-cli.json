{
  "id": "geminiCli",
  "label": "Gemini CLI",
  "short": "Gemini",
  "kebab": "gemini-cli",
  "accent": "#4285F4",
  "icon": "geminicli",
  "wired": true,
  "order": 3,
  "scope": {
    "user": true,
    "project": true
  },
  "detect": {
    "dirs": [
      ".gemini/agents"
    ],
    "agentsDir": ".gemini/agents"
  },
  "version": {
    "bin": "gemini",
    "args": [
      "--version"
    ]
  },
  "format": "gemini-md",
  "slugFrom": "name",
  "dest": {
    "user": [
      ".gemini/agents/{slug}.md"
    ],
    "project": [
      ".gemini/agents/{slug}.md"
    ]
  }
}
