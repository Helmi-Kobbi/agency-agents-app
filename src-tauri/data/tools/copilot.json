{
  "id": "copilot",
  "label": "GitHub Copilot",
  "short": "Copilot",
  "kebab": "copilot",
  "accent": "#6E40C9",
  "icon": "githubcopilot",
  "wired": true,
  "order": 4,
  "scope": {
    "user": true,
    "project": true
  },
  "detect": {
    "dirs": [
      ".github",
      ".copilot"
    ],
    "agentsDir": ".github/agents"
  },
  "version": {
    "bin": "gh",
    "args": [
      "copilot",
      "--version"
    ]
  },
  "format": "identity",
  "slugFrom": "source",
  "dest": {
    "user": [
      ".copilot/agents/{slug}.md",
      ".github/agents/{slug}.md"
    ],
    "project": [
      ".github/agents/{slug}.md"
    ]
  }
}
