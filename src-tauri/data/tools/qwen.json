{
  "id": "qwen",
  "label": "Qwen Code",
  "short": "Qwen",
  "kebab": "qwen",
  "accent": "#615CED",
  "icon": "qwen",
  "wired": true,
  "order": 5,
  "scope": {
    "user": true,
    "project": true
  },
  "detect": {
    "dirs": [
      ".qwen"
    ],
    "agentsDir": ".qwen/agents"
  },
  "version": {
    "bin": "qwen",
    "args": [
      "--version"
    ]
  },
  "format": "qwen-md",
  "slugFrom": "name",
  "dest": {
    "user": [
      ".qwen/agents/{slug}.md"
    ],
    "project": [
      ".qwen/agents/{slug}.md"
    ]
  }
}
